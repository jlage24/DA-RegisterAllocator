# Doxyfile for DA2026 Register Allocator Project

PROJECT_NAME           = "DA2026 - Register Allocator"
PROJECT_NUMBER         = "1.0"
PROJECT_BRIEF          = "Compiler Register Allocation via Graph Coloring"

# Output directory
OUTPUT_DIRECTORY       = docs

# Input sources
INPUT                  = src include
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.cpp

# Extract everything (including private members and static functions)
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES

# Enable HTML output
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_TIMESTAMP         = YES

# Disable LaTeX 
GENERATE_LATEX         = NO

# Enable graphs (requires graphviz)
HAVE_DOT               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
CLASS_DIAGRAMS         = YES
COLLABORATION_GRAPH    = YES
INCLUDE_GRAPH          = YES

# Source code browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO

# Warnings
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES

# Strip the absolute path from file names
STRIP_FROM_PATH        = .

# Sort output
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES